{
  "name": "ai-studio-applet",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development next dev",
    "build": "cross-env NODE_ENV=production next build",
    "start": "node scripts/start-next.mjs",
    "lint": "eslint .",
    "clean": "rm -rf .next .next-dev",
    "auth:migrate": "node --env-file=.env scripts/migrate-better-auth.mjs",
    "storage:migrate": "node --env-file=.env scripts/migrate-storage-assets.mjs",
    "invite:migrate": "node --env-file=.env scripts/migrate-invite-system.mjs",
    "generation-telemetry:migrate": "node --env-file=.env scripts/migrate-generation-telemetry.mjs",
    "test": "node --test tests/*.test.ts tests/*.test.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1020.0",
    "@google/genai": "^1.17.0",
    "@smithy/node-http-handler": "^4.5.1",
    "autoprefixer": "^10.4.21",
    "better-auth": "^1.5.5",
    "lucide-react": "^0.553.0",
    "motion": "^12.23.24",
    "next": "^15.4.9",
    "pg": "^8.20.0",
    "postcss": "^8.5.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "resend": "^6.9.3",
    "sharp": "^0.34.5",
    "undici": "^6.21.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sharp": "^0.31.1",
    "cross-env": "^10.1.0",
    "eslint": "9.39.1",
    "eslint-config-next": "^16.0.8",
    "tailwindcss": "4.1.11",
    "typescript": "5.9.3"
  }
}
