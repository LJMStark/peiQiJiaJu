# Public Gemini API key used by the current client-side AI workflow.
NEXT_PUBLIC_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Server-only Supabase Postgres connection string.
# URL-encode special characters in the password, for example `?` -> `%3F`.
DATABASE_URL="postgresql://user:password@host:6543/postgres"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
