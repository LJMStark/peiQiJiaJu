# Gemini API key used by the server-side AI workflow.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
NEXT_PUBLIC_GEMINI_CLASSIFIER_MODEL="gemini-3-flash-preview"
NEXT_PUBLIC_GEMINI_IMAGE_MODEL="gemini-3-pro-image-preview"

# Connect to Supabase via connection pooling with Supavisor.
# URL-encode special characters in the password, for example `?` -> `%3F`.
DATABASE_URL="postgresql://postgres.project_ref:password@aws-1-region.pooler.supabase.com:6543/postgres"

# Direct database connection for admin tooling or future migrations.
DIRECT_URL="postgresql://postgres:password@db.project_ref.supabase.co:5432/postgres"

# Supabase project URL and service key for private Storage operations.
NEXT_PUBLIC_SUPABASE_URL="https://project_ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Better Auth
BETTER_AUTH_SECRET="change-me-with-a-long-random-secret"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Limit how many room generations can run at the same time across the app.
# Keep this lower than DATABASE_POOL_MAX so the app still has spare query connections.
GENERATION_GLOBAL_CONCURRENCY_LIMIT="2"

# Resend (email sending service for verification emails)
RESEND_API_KEY="re_your_api_key_here"
EMAIL_FROM="佩奇家具 <noreply@yourdomain.com>"

# Cloudflare R2
R2_ACCOUNT_ID="your_cloudflare_account_id"
R2_ACCESS_KEY_ID="your_r2_access_key_id"
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"
R2_BUCKET_NAME="peiqijiaju"
R2_PUBLIC_URL="https://assets.peiqijiaju.xyz"
